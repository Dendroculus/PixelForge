# PixelForge backend environment example
# Copy this file to backend/.env and replace placeholder values.
# Never commit backend/.env.

# --- Environment and security ---
ENVIRONMENT=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pixelforge
AZURE_CONNECTION_STRING=
REPLICATE_API_TOKEN=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
DISCORD_WEBHOOK_URL=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_TURNSTILE_TEST_BYPASS=false

# Forwarded client-IP headers are ignored unless this is true.
TRUST_PROXY_HEADERS=false

# CIDRs for the proxy that connects directly to Uvicorn/FastAPI.
# Leave empty unless your hosting provider documents stable trusted ranges.
TRUSTED_PROXY_CIDRS=

# Official Cloudflare edge networks. Refresh these periodically from:
# https://www.cloudflare.com/ips-v4/
# https://www.cloudflare.com/ips-v6/
CLOUDFLARE_SUBNETS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22,2400:cb00::/32,2606:4700::/32,2803:f800::/32,2405:b500::/32,2405:8100::/32,2a06:98c0::/29,2c0f:f248::/32

# When true, forwarded values are accepted only if the validated proxy chain
# contains a Cloudflare address. This does not firewall direct origin access.
REQUIRE_CLOUDFLARE_PROXY=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_DIR=logs
LOG_FILE_NAME=pixelforge.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
