# PixelForge backend environment example
# Copy this file to backend/.env and replace placeholder values.
# Never commit backend/.env.

# --- Environment and security ---
ENVIRONMENT=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pixelforge
AZURE_CONNECTION_STRING=
REPLICATE_API_TOKEN=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
DISCORD_WEBHOOK_URL=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOW_TURNSTILE_TEST_BYPASS=false

# Forwarded client-IP headers are ignored unless this is true.
TRUST_PROXY_HEADERS=false

# CIDRs for the proxy that connects directly to Uvicorn/FastAPI.
# Leave empty unless the hosting provider documents stable trusted ranges.
TRUSTED_PROXY_CIDRS=

# Official Cloudflare edge CIDRs are required only for verified Cloudflare mode.
# Refresh them from https://www.cloudflare.com/ips-v4/ and /ips-v6/.
CLOUDFLARE_SUBNETS=

# When true, forwarded values are accepted only if the validated proxy chain
# contains Cloudflare. This does not firewall direct origin access.
REQUIRE_CLOUDFLARE_PROXY=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_DIR=logs
LOG_FILE_NAME=pixelforge.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
